# =============================================================================
# MurphyX — Example Environment (framework-level only)
# =============================================================================
# Copy to `.env` locally. Never commit `.env` with real secrets.
#
# Public repo should expose only:
#   LLM · Queue · Database · Runtime · Optional integrations
#
# For local overrides without touching `.env`, use `.env.local`
# (see `.env.local.example` — gitignored by default).
# =============================================================================

# --------------------------------------------------
# 1) ENVIRONMENT — switch behavior (production-grade)
# --------------------------------------------------
# Use in code: if settings.environment == "production": ...
# Typical values: development | staging | production

ENVIRONMENT=development

# --------------------------------------------------
# 2) LOG_LEVEL — critical for agent runtime / worker loop
# --------------------------------------------------
# One of: debug | info | warning | error
# Runtime and orchestrator should read this for structured logging.

LOG_LEVEL=info

# --------------------------------------------------
# 3) LLM — local or cloud (OpenAI / Groq / Anthropic later)
# --------------------------------------------------

LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# When LLM_PROVIDER is openai | groq | anthropic, set:
# LLM_API_KEY=
# LLM_BASE_URL may differ per provider (override as needed).

# --------------------------------------------------
# Queue / task system
# --------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------
# Artifacts (large outputs — refs only in task payloads)
# --------------------------------------------------
# Default: ./artifacts relative to repo root (see murphyx.services.artifact_store)
# ARTIFACTS_ROOT=/var/lib/murphyx/artifacts

# --------------------------------------------------
# Database
# --------------------------------------------------

POSTGRES_URL=postgresql://user:pass@localhost:5432/murphyx

# --------------------------------------------------
# API / control plane (optional)
# --------------------------------------------------

# API_HOST=0.0.0.0
# API_PORT=8000

# --------------------------------------------------
# Optional integrations (no secrets in repo)
# --------------------------------------------------

# GITHUB_TOKEN=
# PLAYWRIGHT_HEADLESS=true

# =============================================================================
# NEVER add these to a public .env.example (business-specific / leaks intent)
# =============================================================================
# BINANCE_API_KEY=
# DISCORD_TOKEN=
# SCRAPER_PROXY=
# TRADE_ACCOUNT=
# STRIPE_SECRET=
#
# Keeping the framework generic avoids the repo looking like one vertical
# product; put proprietary keys only in private .env / secret manager.
# =============================================================================
