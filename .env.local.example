# =============================================================================
# .env.local.example — local overrides for developers
# =============================================================================
# Copy to `.env.local` (gitignored). Loads after `.env` if your loader supports it.
# Bonus pattern used by mature repos: defaults in .env.example, personal tweaks here.
# =============================================================================

# Example overrides — safe placeholders only

LLM_MODEL=llama3
LOG_LEVEL=debug

# Optional: point at a different local model without editing shared .env
# LLM_BASE_URL=http://localhost:11434
